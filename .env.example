# Chaves de API (Copie este arquivo para .env e insira suas chaves)
GEMINI_API_KEY="sua_chave_gemini_aqui"
OPENROUTER_API_KEY="sua_chave_openrouter_aqui"

# Escolha de Modelos (Você pode alterar para os modelos disponíveis)
GEMINI_TRANSCRIPTION_MODEL="gemini-1.5-flash"
OPENROUTER_DIDACTIC_MODEL="google/gemini-flash-1.5" # Substitua pelo modelo desejado no OpenRouter
